# ============================================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# Never commit the actual .env file to version control
# ============================================================

# --- WNI WEBSITE CREDENTIALS ---
WN_USERNAME=your_wni_username@example.com
WN_PASSWORD=your_wni_password
WNI_LOGIN_URL=https://vp.weathernews.com/public/gp/index.html#/login

# --- DATABASE CREDENTIALS ---
DB_USER=postgres
DB_PASSWORD=root
DB_HOST=localhost
DB_PORT=5432
DB_NAME=noon_reports_db
DATABASE_URL=postgresql://postgres:root@localhost:5432/noon_reports_db

# --- MARIAPPS CREDENTIALS ---
MARIAPPS_URL=https://your-mariapps-instance.com/Home/Landing
MARIAPPS_DEFAULT_VESSEL=VESSEL NAME

# Microsoft SSO login for the automated MariApps scraper.
# This account MUST have MFA/2FA disabled so the login can run headless (cron).
MARIAPPS_USERNAME=pms@example.com
MARIAPPS_PASSWORD=your_mariapps_password

# Directory to store downloaded MariApps data files
# Leave unset to use the default: <project_root>/data/mariapps
MARIAPPS_DOWNLOAD_DIR=/opt/vessel_pipeline/data/mariapps

# Set to "false" on your local machine to see the browser window during scraping
# Must be "true" on the Azure VM (no display available)
MARIAPPS_HEADLESS=true

# --- CORS (comma-separated list of allowed frontend origins) ---
# Example for local dev: http://localhost:3000,http://localhost:5173
# Example for production: https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- EMAIL CONFIGURATION ---

# --- OPTION 1: AZURE AD (MICROSOFT 365) - RECOMMENDED ---
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret

# --- OPTION 2: STANDARD SMTP (GMAIL, ETC.) ---
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587

# --- COMMON EMAIL SETTINGS ---
MAIL_FROM=your_email@gmail.com
MAIL_FROM_NAME=Maritime Noon Report System

# Recipients (comma-separated, no spaces)
MAIL_TO=recipient@example.com

# --- EYEGAUGE CREDENTIALS ---
EYEGAUGE_BASE_URL=https://sea.vision
EYEGAUGE_USERNAME=your_eyegauge_username
EYEGAUGE_PASSWORD=your_eyegauge_password
EYEGAUGE_TELEMETRY_KEYS=speed,course,latitude,longitude,me_flow_meter,ae_flow_meter
